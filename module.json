{
  "id": "foundry-tile-highlight-module",
  "title": "Tile Hover Highlight",
  "description": "Highlights placed tiles with an outline on cursor hover. Works for any user and can be toggled per scene.",
  "version": "1.0.1",
  "compatibility": {
    "minimum": "13",
    "verified": "13",
    "maximum": "13"
  },
  "authors": [
    {
      "name": "Lumiel"
    }
  ],
  "esmodules": [
    "scripts/module.js"
  ],
  "relationships": {
    "recommends": [
      {
        "id": "lib-wrapper",
        "type": "module",
        "reason": "Used to override ClientSettings.get without conflicting with other modules."
      }
    ]
  },
  "styles": [
    "styles/module.css"
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "languages/en.json"
    },
    {
      "lang": "ru",
      "name": "Русский",
      "path": "languages/ru.json"
    }
  ],
  "url": "https://github.com/Frost-Jack/foundry-tile-highlight-module",
  "manifest": "https://github.com/Frost-Jack/foundry-tile-highlight-module/releases/latest/download/module.json",
  "download": "https://github.com/Frost-Jack/foundry-tile-highlight-module/releases/latest/download/module.zip",
  "license": "LICENSE",
  "readme": "README.md"
}
